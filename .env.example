# SignalForge environment variables
# Copy this file to .env and fill in values

# LLM Provider
# Supported: anthropic (claude), openai (gpt-4o)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Signal Sources
JSEARCH_API_KEY=
TAVILY_API_KEY=

# Backend server
SIGNALFORGE_HOST=0.0.0.0
SIGNALFORGE_PORT=8000

# Optional: override config dir for testing
# SIGNALFORGE_CONFIG_DIR=/tmp/signalforge-test

# LangSmith Tracing (optional — enables LangGraph observability in LangSmith UI)
# Set LANGCHAIN_TRACING_V2=true to emit traces for every pipeline run.
# Traces include per-node latency, token counts, and HITL interrupt events.
# Consumed directly by the LangChain runtime — no code changes required.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=signalforge
